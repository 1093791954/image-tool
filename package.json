{
  "name": "image-tools",
  "version": "1.0.0",
  "description": "Local desktop image generation tool for OpenAI-compatible image APIs.",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json && powershell -NoProfile -Command \"Copy-Item -LiteralPath electron/preload.cjs -Destination dist-electron/preload.cjs -Force\"",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "pack:win": "npm run dist",
    "pack:portable": "npm run build && powershell -ExecutionPolicy Bypass -File scripts/pack-portable.ps1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "electron-store": "^10.1.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "top.api-corp.image-tools",
    "productName": "GPT Image Tools",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
